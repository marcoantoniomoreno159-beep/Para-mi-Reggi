<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tengo una pregunta para ti... ❤️</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #ffe6e6, #ffb3b3);
            text-align: center;
            overflow: hidden;
            position: relative;
        }

        .contenedor {
            background-color: rgba(255, 255, 255, 0.8);
            padding: 40px 30px;
            border-radius: 25px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 10;
            max-width: 90%;
            width: 450px;
            transition: all 0.5s ease;
        }

        h1 {
            color: #d63031;
            font-size: 2.2rem;
            margin-bottom: 15px;
            line-height: 1.3;
        }

        p {
            color: #555;
            font-size: 1.1rem;
            margin-bottom: 35px;
            line-height: 1.5;
        }

        .zona-botones {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            min-height: 60px;
            position: relative;
        }

        button {
            padding: 14px 30px;
            font-size: 1.1rem;
            font-weight: bold;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.2s ease, background-color 0.2s ease;
        }

        #btnSi {
            background-color: #ff4757;
            color: white;
            z-index: 11;
        }

        #btnSi:hover {
            transform: scale(1.1);
            background-color: #ff6b81;
        }

        #btnNo {
            background-color: #a4b0be;
            color: white;
            position: absolute;
            z-index: 12;
            will-change: top, left;
        }

        /* Animación para los corazones flotantes */
        .corazon {
            position: absolute;
            color: #ff4757;
            pointer-events: none;
            animation: flotar 4s linear infinite;
            opacity: 0;
        }

        @keyframes flotar {
            0% {
                transform: translateY(100vh) scale(0) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.8;
            }
            90% {
                opacity: 0.8;
            }
            100% {
                transform: translateY(-10vh) scale(1.2) rotate(360deg);
                opacity: 0;
            }
        }
    </style>
</head>
<body>

    <div class="contenedor" id="tarjeta">
        <!-- Puedes editar esta pregunta directamente -->
        <h1 id="titulo">¿Quieres salir conmigo hoy a una cita? 🌹</h1>
        
        <!-- Puedes editar este sutil mensaje de abajo -->
        <p id="subtitulo">Prometo que habrá comida deliciosa, risas y un gran momento juntos mi amor.</p>
        
        <div class="zona-botones">
            <button id="btnSi" onclick="aceptarPropuesta()">¡SÍ! 🥰</button>
            <button id="btnNo" onmouseover="moverBoton()" onclick="moverBoton()">No 😢</button>
        </div>
    </div>

    <script>
        function aceptarPropuesta() {
            // EDITAR AQUÍ: Modifica los textos que aparecerán cuando presione "SÍ"
            document.getElementById('titulo').innerHTML = "¡SIII! 🎉❤️";
            document.getElementById('subtitulo').innerHTML = "¡Me haces el más feliz mi Reggi! Alístate hoy, yo me encargo de todo el plan, ya se que te cuesta pero dejame intentarlo mi amor. Te paso a buscar a las 7:00 PM. ¡Te amo!";
            
            // Ocultamos los botones
            document.querySelector('.zona-botones').style.display = 'none';
            
            // Inicia la lluvia de corazones automáticos
            lluviaDeCorazones();
        }

        function moverBoton() {
            const btnNo = document.getElementById('btnNo');
            
            // Calculamos un área segura dentro de la pantalla para que no se salga
            const anchoVentana = window.innerWidth - btnNo.offsetWidth - 20;
            const altoVentana = window.innerHeight - btnNo.offsetHeight - 20;
            
            // Generar posiciones aleatorias
            const aleatorioX = Math.max(10, Math.floor(Math.random() * anchoVentana));
            const aleatorioY = Math.max(10, Math.floor(Math.random() * altoVentana));
            
            // Aplicar las nuevas coordenadas
            btnNo.style.left = aleatorioX + 'px';
            btnNo.style.top = aleatorioY + 'px';
        }

        function lluviaDeCorazones() {
            // Crea 40 corazones flotando hacia arriba en tiempos distintos
            for (let i = 0; i < 40; i++) {
                setTimeout(() => {
                    const corazon = document.createElement('div');
                    corazon.classList.add('corazon');
                    corazon.innerHTML = '❤️';
                    
                    // Configuraciones aleatorias para que se vea natural
                    corazon.style.left = Math.random() * 100 + 'vw';
                    corazon.style.fontSize = (Math.random() * 20 + 15) + 'px';
                    corazon.style.animationDuration = (Math.random() * 2 + 3) + 's'; 
                    
                    document.body.appendChild(corazon);
                    
                    // Eliminar el elemento después de que termine la animación
                    setTimeout(() => corazon.remove(), 5000);
                }, i * 150);
            }
        }
    </script>
</body>
</html>
